{
    "Plugins": [
        {
            "Type": "library",
            "Name": "{{Name}}Exec",
            "Root": ".",
            "LibraryPath": "../../../lib/@OPENSTRATA_PLUGIN_LIBRARY_PREFIX@{{Name}}Exec@CMAKE_SHARED_LIBRARY_SUFFIX@",
            "ResourcePath": ".",
            "Info": {
                "Exec": {
                    "Schemas": {
                        "{{SchemaType}}": {
                            "allowsPluginComputations": true
                        }
                    }
                }
            }
        }
    ]
}
