          "Hd{{Name}}RendererPlugin": {
            "bases": ["HdRendererPlugin"],
            "displayName": "{{Name}}",
            "priority": 0
          }
        }
      },
      "LibraryPath": "@{{NAME}}_HYDRA_LIBRARY_NAME@",
