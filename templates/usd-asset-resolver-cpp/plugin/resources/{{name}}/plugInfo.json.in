{
    "Plugins": [
        {
            "Type": "library",
            "Name": "{{Name}}Resolver",
            "Root": ".",
            "LibraryPath": "../../../lib/@OPENSTRATA_PLUGIN_LIBRARY_PREFIX@{{Name}}Resolver@CMAKE_SHARED_LIBRARY_SUFFIX@",
            "ResourcePath": ".",
            "Info": {
                "Types": {
                    "{{Name}}Resolver": {
                        "bases": ["ArResolver"],
                        "displayName": "{{Name}} Asset Resolver",
                        "uriSchemes": ["{{scheme}}"]
                    }
                }
            }
        }
    ]
}
