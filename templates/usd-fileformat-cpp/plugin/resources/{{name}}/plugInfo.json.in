{
    "Plugins": [
        {
            "Type": "library",
            "Name": "{{Name}}FileFormat",
            "Root": ".",
            "LibraryPath": "../../../lib/@OPENSTRATA_PLUGIN_LIBRARY_PREFIX@{{Name}}FileFormat@CMAKE_SHARED_LIBRARY_SUFFIX@",
            "ResourcePath": ".",
            "Info": {
                "Types": {
                    "{{Name}}FileFormat": {
                        "bases": ["SdfFileFormat"],
                        "displayName": "{{Name}} File Format",
                        "extensions": ["{{extension}}"],
                        "formatId": "{{extension}}",
                        "primary": true,
                        "target": "usd"
                    }
                }
            }
        }
    ]
}
