{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/animu-sphere/open-strata/main/schemas/plugin-report.schema.json",
  "title": "OpenStrata Plugin Verification Report",
  "description": "report.json written under .strata/reports/<plugin>/<UTC-timestamp>/ by `ost plugin doctor|inspect|test`. The `ost plugin doctor --json` stdout is a superset of the on-disk file: it additionally carries `report_dir` and `environment`.",
  "type": "object",
  "required": ["schema", "plugin", "kind", "passed", "summary", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "integer", "const": 1 },
    "plugin": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["usd-fileformat", "usd-asset-resolver", "usd-schema"]
    },
    "passed": { "type": "boolean" },
    "report_dir": {
      "type": "string",
      "description": "Only on `doctor`/`test` --json stdout: the report directory just written. Absent from the on-disk report.json."
    },
    "environment": {
      "type": "object",
      "description": "Only on `doctor --json` stdout: the session env preview (mirrors environment.json). Absent from the on-disk report.json.",
      "required": ["separator", "vars"],
      "additionalProperties": false,
      "properties": {
        "separator": { "type": "string" },
        "vars": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["pass", "fail", "skip"],
      "additionalProperties": false,
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "status", "observed", "suggested_actions"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable diagnostic id, e.g. bundle.manifest, runtime.openusd.version, dependency.<component>.",
            "minLength": 1
          },
          "level": {
            "type": "integer",
            "description": "Verification pyramid level (0=structure .. 6=usdview).",
            "minimum": 0,
            "maximum": 6
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skip"]
          },
          "observed": { "type": "string" },
          "suggested_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
