{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/animu-sphere/open-strata/main/schemas/plugin-report.schema.json",
  "title": "OpenStrata Plugin Verification Report",
  "description": "report.json written under .strata/reports/<plugin>/<UTC-timestamp>/ by `ost plugin doctor|inspect|test`. The `ost plugin doctor --json` stdout is a superset of the on-disk file: it additionally carries `report_dir` and `environment`.",
  "type": "object",
  "required": ["schema", "plugin", "kind", "passed", "summary", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "integer", "const": 1 },
    "plugin": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": [
        "usd-fileformat",
        "usd-asset-resolver",
        "usd-package-resolver",
        "usd-exec",
        "usd-schema"
      ]
    },
    "license": {
      "type": ["string", "null"],
      "description": "SPDX license expression for the plugin's own code, from the bundle manifest. Null when the manifest declares none."
    },
    "passed": { "type": "boolean" },
    "report_dir": {
      "type": "string",
      "description": "Only on `doctor`/`test` --json stdout: the report directory just written. Absent from the on-disk report.json."
    },
    "environment": {
      "type": "object",
      "description": "Only on `doctor --json` stdout: the session env preview (mirrors environment.json). Absent from the on-disk report.json.",
      "required": ["separator", "vars"],
      "additionalProperties": false,
      "properties": {
        "separator": { "type": "string" },
        "vars": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "libraries": {
      "type": "array",
      "description": "Resolved plain-library closure on inspect/test JSON stdout. The on-disk companion is dependencies.json.",
      "items": {
        "type": "object",
        "required": ["id", "version", "descriptor", "cmake_package", "cmake_target", "prefix", "runtime_directories", "provenance"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "descriptor": { "type": "string", "minLength": 1 },
          "cmake_package": { "type": "string", "minLength": 1 },
          "cmake_target": { "type": "string", "minLength": 1 },
          "prefix": { "type": ["string", "null"] },
          "runtime_directories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "provenance": { "type": "string", "enum": ["source-workspace"] }
        }
      }
    },
    "dependencies_file": {
      "type": "string",
      "description": "Only on test JSON stdout when a plain-library closure exists: path to dependencies.json in the report directory."
    },
    "ci": {
      "type": "object",
      "description": "CI evidence, present only when the run happened inside a generated CI job (the job exports OST_CI_* variables): which support cell this report proves, on which lane and runner, against which pinned artifacts and effective trust floor. Fields other than `cell` are null when the job did not export them.",
      "required": ["cell"],
      "additionalProperties": false,
      "properties": {
        "cell": { "type": "string", "minLength": 1 },
        "lane": {
          "type": ["string", "null"],
          "enum": ["pull_request", "main", "scheduled", "workflow_dispatch", null]
        },
        "runner_profile": { "type": ["string", "null"] },
        "runs_on": {
          "type": ["string", "null"],
          "description": "The resolved runs-on labels, comma-joined."
        },
        "runtime_artifact": { "type": ["string", "null"] },
        "plugin_artifact": { "type": ["string", "null"] },
        "minimum_trust": {
          "type": ["string", "null"],
          "enum": ["local", "unsigned", "attested", "verified", "trusted", null]
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["pass", "fail", "skip"],
      "additionalProperties": false,
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "status", "observed", "suggested_actions"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable diagnostic id, e.g. bundle.manifest, runtime.openusd.version, dependency.<component>.",
            "minLength": 1
          },
          "level": {
            "type": "integer",
            "description": "Verification pyramid level (0=structure .. 6=usdview).",
            "minimum": 0,
            "maximum": 6
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skip"]
          },
          "observed": { "type": "string" },
          "suggested_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
