{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstrata.dev/schemas/formation.schema.json",
  "title": "OpenStrata Formation Manifest",
  "description": "A digest-pinned runtime and packaged component set composed for one foreground command.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "formation", "runtime", "command"],
  "properties": {
    "schema": { "const": "openstrata.formation/v1alpha1" },
    "formation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/id" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact"],
      "properties": {
        "artifact": { "$ref": "#/$defs/digest" }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "artifact"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "kind": { "enum": ["plugin", "renderer"] },
          "artifact": { "$ref": "#/$defs/digest" }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["program"],
      "properties": {
        "program": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
