{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/animu-sphere/open-strata/main/schemas/renderer-report.schema.json",
  "title": "OpenStrata Renderer Report",
  "description": "Deterministic PASS/FAIL/SKIP evidence emitted by a renderer project.",
  "type": "object",
  "required": ["schema", "renderer", "checks"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "string", "const": "openstrata.renderer-report/v1alpha1" },
    "renderer": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
          },
          "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "detail": { "type": "string" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "status": { "enum": ["fail", "skip"] } },
              "required": ["status"]
            },
            "then": {
              "required": ["detail"],
              "properties": { "detail": { "minLength": 1 } }
            }
          }
        ]
      }
    }
  }
}
