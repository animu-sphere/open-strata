{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstrata.dev/schemas/plugin-activation.schema.json",
  "title": "OpenStrata packaged plugin activation contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "target_os",
    "root",
    "environment",
    "plugin_paths",
    "library_paths",
    "python_paths",
    "entrypoints",
    "python_dll_search"
  ],
  "properties": {
    "schema": { "const": "openstrata.activation/v1alpha1" },
    "target_os": { "enum": ["linux", "macos", "windows"] },
    "root": { "const": "." },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin", "loader", "python"],
      "properties": {
        "plugin": { "const": "PXR_PLUGINPATH_NAME" },
        "loader": { "enum": ["LD_LIBRARY_PATH", "DYLD_LIBRARY_PATH", "PATH"] },
        "python": { "const": "PYTHONPATH" }
      }
    },
    "plugin_paths": { "$ref": "#/$defs/portablePaths" },
    "library_paths": { "$ref": "#/$defs/portablePaths" },
    "python_paths": { "$ref": "#/$defs/portablePaths" },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["powershell", "bash", "python"],
      "properties": {
        "powershell": { "const": "activate.ps1" },
        "bash": { "const": "activate.sh" },
        "python": { "const": "openstrata_activate.py" }
      }
    },
    "python_dll_search": {
      "type": "object",
      "additionalProperties": false,
      "required": ["windows"],
      "properties": {
        "windows": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "portablePaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[^\\\\:/]+(?:/[^\\\\/]+)*$"
      }
    }
  }
}
