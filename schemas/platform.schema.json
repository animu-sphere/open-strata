{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openstrata.dev/schemas/platform.schema.json",
  "title": "OpenStrata Platform Manifest",
  "description": "A machine-readable VFX Reference Platform calendar-year definition.",
  "type": "object",
  "required": ["id", "source", "core"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cy[0-9]{4}$",
      "description": "Calendar-year id, e.g. cy2026."
    },
    "source": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["vfx-reference-platform", "custom"]
        },
        "status": {
          "type": "string",
          "enum": ["draft", "final", "superseded"],
          "default": "draft"
        }
      }
    },
    "core": {
      "type": "object",
      "description": "Component -> version constraint map.",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "notes": {
      "type": "string"
    }
  }
}
