{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/animu-sphere/open-strata/main/schemas/project.schema.json",
  "title": "OpenStrata Project Manifest",
  "description": "The openstrata.toml authored at a project root.",
  "type": "object",
  "required": ["project", "requires"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "default": "0.1.0" },
        "version_file": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "requires": {
      "type": "object",
      "required": ["platform"],
      "additionalProperties": false,
      "properties": {
        "platform": { "type": "string", "pattern": "^cy[0-9]{4}$" },
        "profile": { "type": "string", "default": "core" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extensions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "compiler": { "type": "string", "enum": ["host", "runtime", "explicit"], "default": "host" },
        "cc": { "type": "string" },
        "cxx": { "type": "string" },
        "intents": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$", "not": { "const": "default" } },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "cache": {
                "type": "object",
                "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
                "additionalProperties": {
                  "type": "object",
                  "required": ["type", "value"],
                  "additionalProperties": false,
                  "properties": {
                    "type": { "type": "string", "enum": ["BOOL", "STRING", "PATH", "FILEPATH"] },
                    "value": { "type": ["boolean", "string"] },
                    "portability": { "type": "string", "enum": ["portable", "local-override"] }
                  },
                  "allOf": [
                    {
                      "if": { "properties": { "type": { "const": "BOOL" } } },
                      "then": { "properties": { "value": { "type": "boolean" } } },
                      "else": { "properties": { "value": { "type": "string" } } }
                    },
                    {
                      "if": { "properties": { "type": { "enum": ["PATH", "FILEPATH"] } } },
                      "then": { "required": ["portability"] },
                      "else": { "not": { "required": ["portability"] } }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
