{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstrata.dev/schemas/plugin-product.schema.json",
  "title": "OpenStrata aggregate plugin product contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "name", "version", "target", "install", "members"],
  "properties": {
    "schema": { "const": "openstrata.plugin-product/v1alpha1" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "order", "contract"],
      "properties": {
        "layout": { "const": "members/<bundle-id>/" },
        "destination": { "const": "bundles/<bundle-id>/" },
        "order": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "activation": { "const": "openstrata.activation.json" },
        "contract": { "type": "string", "minLength": 1 }
      }
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/member" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-fA-F]{64}$"
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "position",
        "name",
        "version",
        "kind",
        "archive",
        "archive_digest",
        "archive_size",
        "manifest",
        "checksums",
        "evidence",
        "debug",
        "dependencies"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "position": { "type": "integer", "minimum": 0 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "archive": { "type": "string", "pattern": "^members/[^/]+/[^/]+\\.tar\\.zst$" },
        "archive_digest": { "$ref": "#/$defs/sha256" },
        "archive_size": { "type": "integer", "minimum": 0 },
        "manifest": { "type": "string", "pattern": "^members/[^/]+/manifest\\.json$" },
        "checksums": { "type": "string", "pattern": "^members/[^/]+/SHA256SUMS$" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^members/[^/]+/[^/]+$" }
        },
        "debug": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["archive", "archive_digest", "archive_size"],
              "properties": {
                "archive": { "type": "string", "pattern": "^members/[^/]+/[^/]+-debug\\.tar\\.zst$" },
                "archive_digest": { "$ref": "#/$defs/sha256" },
                "archive_size": { "type": "integer", "minimum": 0 }
              }
            }
          ]
        },
        "dependencies": {
          "oneOf": [{ "type": "null" }, { "type": "object" }]
        }
      }
    }
  }
}
