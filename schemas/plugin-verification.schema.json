{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstrata.dev/schemas/plugin-verification.schema.json",
  "title": "OpenStrata packaged plugin verification-content contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "oracle_convention", "roundtrip"],
  "properties": {
    "schema": { "const": "openstrata.plugin-verification/v1alpha1" },
    "oracle_convention": { "const": "<fixture>.golden.usda" },
    "roundtrip": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fixture", "fixture_sha256", "oracle", "oracle_sha256"],
        "properties": {
          "fixture": { "$ref": "#/$defs/portablePath" },
          "fixture_sha256": { "$ref": "#/$defs/sha256" },
          "oracle": { "$ref": "#/$defs/portablePath" },
          "oracle_sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\\\:/]+(?:/[^\\\\/]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
