# Normalize line endings: LF in the repo, regardless of host OS.
# Linux x86_64 is the first-class build target, so LF is canonical.
* text=auto eol=lf

# Windows-only scripts must stay CRLF to run correctly.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Treat known binaries as binary (no eol munging, no textual diff).
*.zst  binary
*.tar  binary
*.png  binary
*.jpg  binary
*.exr  binary
*.usdc binary
*.usdz binary

# Generated lockfiles: keep textual but mark for clearer review handling.
Cargo.lock linguist-generated=true
